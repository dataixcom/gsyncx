{
  "job_id": "user-field-mapping-sync-001",
  "job_name": "用户表字段映射同步",
  "version": "1.0.0",
  "reader": {
    "type": "database",
    "dsn_config": {
      "db_type": "mysql",
      "host": "10.1.1.100",
      "port": 33068,
      "user": "root",
      "password": "Dataix@2025",
      "schema": "phoenix-dev",
      "max_idle": 5,
      "max_open": 20
    },
    "table_name": "t_sys_user",
    "primary_key": {
      "field_name": "id"
    },
    "where_clause": "status = 'active'",
    "fields": [
      {"field_name": "id"},
      {"field_name": "tid"},
      {"field_name": "account"},
      {"field_name": "password"},
      {"field_name": "nick_name"},
      {"field_name": "email"},
      {"field_name": "phone"},
      {"field_name": "create_time"}
    ]
  },
  "mapping": {
    "mappings": [
      {
        "source_field": "id",
        "target_field": "id",
        "required": true
      },
      {
        "source_field": "tid",
        "target_field": "tid"
      },
      {
        "source_field": "account",
        "target_field": "account"
      },
      {
        "source_field": "password",
        "target_field": "password"
      },
      {
        "source_field": "nick_name",
        "target_field": "display_name"
      },
      {
        "source_field": "email",
        "target_field": "contact_email",
        "transform": "trim"
      },
      {
        "source_field": "phone",
        "target_field": "contact_phone"
      },
      {
        "source_field": "create_time",
        "target_field": "registered_at"
      }
    ],
    "default_values": {
      "sync_source": "phoenix-dev",
      "synced_at": "NOW()"
    },
    "auto_mapping": true,
    "ignore_missing": true
  },
  "writer": {
    "type": "database",
    "dsn_config": {
      "db_type": "mysql",
      "host": "10.1.1.100",
      "port": 33068,
      "user": "root",
      "password": "Dataix@2025",
      "schema": "dx-test-go",
      "max_idle": 5,
      "max_open": 20
    },
    "table_name": "t_sys_user",
    "write_mode": "upsert",
    "primary_key": {
      "field_name": "id"
    },
    "use_transaction": true,
    "batch_size": 500
  },
  "setting": {
    "sync_mode": "full",
    "batch_size": 1000,
    "parallelism": 4,
    "retry_max_attempts": 3,
    "retry_delay": 5000000000,
    "continue_on_error": true,
    "integrity_check": "count"
  }
}
